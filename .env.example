# === Required ===
TG_BOT_TOKEN=your_telegram_bot_token

# === AI (natural language + voice) ===
# Get OpenRouter key: https://openrouter.ai/keys
AI_API_KEY=your_openrouter_api_key
AI_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL=z-ai/glm-5.2

# Voice transcription (Gemini 2.5 Flash)
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key
STT_PROVIDER=gemini

# === Push notifications ===
# Get Bark: https://apps.apple.com/app/bark-push-notifications/id1403753865
DEFAULT_WEBHOOK_URL=https://api.day.app/your_bark_key

# === Server ===
PUBLIC_URL=https://todo.yourdomain.com
TZ_OFFSET_HOURS=8
DB_PATH=./data.db
PORT=9753
